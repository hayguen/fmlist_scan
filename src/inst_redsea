
BASE=$(pwd)

# https://github.com/windytan/redsea.git
GITUSER=windytan
GITPROJ=redsea

cd ${BASE}/git/${GITUSER}/${GITPROJ}
# make install not necessary
# new installation procedure since v1.0

meson setup build && cd build
taskset -c 0 meson compile # will only use one CPU for compiling, see https://github.com/windytan/redsea/issues/120
meson install

cd ${BASE}

